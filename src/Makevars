CXX_STD = CXX14

# Force RcppParallel's TinyThread backend (header-only). Avoids linking
# against TBB / tbbmalloc — on Windows, RcppParallel::RcppParallelLibs()
# returns linker flags pointing at tbb.dll / tbbmalloc.dll inside the
# RcppParallel installation, which are NOT on the default DLL search
# path at load time, so loading nicher.dll fails with
#   "LoadLibrary failure: The specified module could not be found".
# TinyThread is header-only, so we get parallelFor() with no extra
# runtime DLL on any platform. Same flag is set in src/Makevars.win.
PKG_CXXFLAGS = -DRCPP_PARALLEL_USE_TBB=0 \
               $(shell "${R_HOME}/bin/Rscript" -e "RcppParallel::CxxFlags()")
PKG_LIBS = $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)
