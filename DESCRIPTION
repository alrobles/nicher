Package: nicher
Type: Package
Title: Estimates Ecological Niche Models Using Ellipses
Version: 1.0.0
Authors@R: 
  c(person(given = "Angel",
           family = "Robles",
           email = "a.l.robles.fernandez@gmail.com",
           role = c("aut", "cre")),
    person(given = "Laura",
           family = "Jimenez",
